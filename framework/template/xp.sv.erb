<%
  module_name = @xp_module_name || "xp_router_#{@xp.id}"
  local_port_count = @xp_local_port_count || @xp.endpoints.size
  direction_order = [
    { name: :east,  abbr: 'e', label: 'E' },
    { name: :west,  abbr: 'w', label: 'W' },
    { name: :north, abbr: 'n', label: 'N' },
    { name: :south, abbr: 's', label: 'S' }
  ]
  active_links = if @xp_port_directions
                   @xp_port_directions
                 else
                   @xp.neighbors(@noc).filter_map do |nb|
                     conn = @connections.find { |c| (c.from == @xp.id && c.to == nb.id) || (c.to == @xp.id && c.from == nb.id) }
                     next unless conn

                     { name: (conn.dir || 'auto').to_s.downcase.to_sym, abbr: (conn.dir || 'a').to_s[0], neighbor: nb, connection: conn }
                   end
                 end
  links_by_direction = active_links.group_by { |link| link[:name] }
%>
//----------------------------------------------------------------------------
// Auto-generated by finepaper | NoC: <%= @name %> v<%= @version %>
//----------------------------------------------------------------------------
//#========================================================================
//#
//#  SMXP: Synthetic Mesh Cross Point
//#
//#========================================================================
//#
//# Module
//# ======
//  - module_name       : <%= module_name %>
//  - source_xp         : <%= @xp.id %>
//  - node_id           : <%= @xp.node_id(@noc) %>
//  - position          : (<%= @xp.x %>, <%= @xp.y %>)
//  - variant_signature : <%= @xp_variant_signature || 'per-xp' %>
//  - local_ports       : <%= local_port_count %>
//#
//# Crosspoint Configuration
//# ========================
//  - DATA_WIDTH        : <%= @parameters['data_width'] %>
//  - FLIT_WIDTH        : <%= @parameters['flit_width'] %>
//  - ADDR_WIDTH        : <%= @parameters['addr_width'] %>
//  - routing_algorithm : <%= @xp.config[:routing_algorithm] %>
//  - virtual_channels  : <%= @xp.config[:vc_count] %>
//  - buffer_depth      : <%= @xp.config[:buffer_depth] %>
//  - endpoint_slots    : <%= @xp.endpoints.empty? ? 'none' : @xp.endpoints.join(', ') %>
//#
//# Mesh Port Matrix
//# ================
<% direction_order.each do |dir| %>
//# Mesh Port: <%= dir[:label] %>
<% links = links_by_direction.fetch(dir[:name], [])
   if links.empty? %>
//  - state            : not present for this variant
<% else
     links.each_with_index do |link, index|
       neighbor = link[:neighbor]&.id || 'external'
       port = link[:port] || link[:abbr] || dir[:abbr] %>
//  - slice<%= index %>           : neighbor=<%= neighbor %> port_suffix=<%= port %> virtual_networks=REQ,RSP,DAT,SNP,PUB credit_mode=local-return
<%   end
   end %>
<% end %>
//#
//# Protocol Channel Placeholders
//# =============================
//  - REQ : address/control request flits, ordered by routing class
//  - RSP : response flits with completion and retry status
//  - DAT : data flits with poison/check metadata carried beside payload
//  - SNP : snoop request/response placeholders for coherent fabrics
//  - PUB : public configuration and maintenance sideband channel
//#
//# Internal Signals - Automatic Declarations
//# =========================================
//  - route_select_table[local, E, W, N, S]
//  - ingress_credit_count[virtual_channel]
//  - egress_credit_count[virtual_channel]
//  - qos_arbiter_grant[REQ, RSP, DAT, SNP, PUB]
//  - vc_occupancy_snapshot[local_port][virtual_channel]
//----------------------------------------------------------------------------

module <%= module_name %> #(
  parameter DATA_WIDTH = <%= @parameters['data_width'] %>,
  parameter FLIT_WIDTH = <%= @parameters['flit_width'] %>,
  parameter ADDR_WIDTH = <%= @parameters['addr_width'] %>
) (
  input  logic clk,
  input  logic rst_n,
  // <%= @xp_port_directions ? "Local endpoint slots: #{local_port_count}" : "Endpoints: #{@xp.endpoints.join(', ')}" %>
<%
  ports = []
  if @xp_port_directions
    # Variant XP modules use direction-based ports so one module can be reused
    # by every coordinate with the same E/W/N/S connectivity.
    @xp_port_directions.each do |link|
      port = link[:port] || link[:abbr]
      ports << "  // Link #{port.upcase}\n  input  logic [FLIT_WIDTH-1:0] flit_in_#{port}"
      ports << "  output logic [FLIT_WIDTH-1:0] flit_out_#{port}"
    end
    local_port_count.times do |idx|
      ports << "  input  logic [FLIT_WIDTH-1:0] local#{idx}_flit_in"
      ports << "  output logic [FLIT_WIDTH-1:0] local#{idx}_flit_out"
    end
  else
    # Neighbor connection ports
    @xp.neighbors(@noc).each do |nb|
      dir = @connections.find { |c| (c.from == @xp.id && c.to == nb.id) || (c.to == @xp.id && c.from == nb.id) }&.dir
      ports << "  // Link to #{nb.id} (#{dir})\n  input  logic [FLIT_WIDTH-1:0] flit_in_#{nb.id}"
      ports << "  output logic [FLIT_WIDTH-1:0] flit_out_#{nb.id}"
    end
    # Endpoint ports
    @xp.endpoints.each do |ep_id|
      ep = @noc.endpoints.find { |e| e.id == ep_id }
      if ep&.ports&.any?
        ep.ports.each { |p| ports << "  #{p.dir.ljust(6)} logic#{p.width ? " [#{p.width}]" : ''} #{ep_id}_#{p.name}" }
      else
        ports << "  input  logic [FLIT_WIDTH-1:0] #{ep_id}_flit_in"
        ports << "  output logic [FLIT_WIDTH-1:0] #{ep_id}_flit_out"
      end
    end
  end
%>
<%= ports.join(",\n") %>
);

  //# Parameter Conversion Notes
  //# ==========================
  // This generated shell intentionally mirrors the shape of production NoC IP:
  // config values are surfaced here so reports show routing, buffering, and
  // credit policy next to the structural port map.
  //
  // u_route_decode:
  //   - consumes destination node id and selected virtual channel
  //   - applies <%= @xp.config[:routing_algorithm].upcase %> routing preference
  //   - arbitrates between local egress and mesh directions
  //
  // u_credit_accounting:
  //   - tracks <%= @xp.config[:vc_count] %> virtual channels
  //   - assumes <%= @xp.config[:buffer_depth] %> flit entries per ingress queue
  //   - returns local credits on simplified flit acceptance
  //
  // u_channel_switch:
  //   - maps compact demo flits onto REQ/RSP/DAT/SNP/PUB placeholder channels
  //   - preserves the existing finepaper single-flit interface for tests
endmodule
