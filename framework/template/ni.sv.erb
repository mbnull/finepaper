<%
  endpoint_by_id = @noc.endpoints.to_h { |ep| [ep.id, ep] }
  module_name = @ni_module_name || "ni_xp_#{@xp.id}"
  ni_features = {
    'protocol_decode' => true,
    'request_queue' => true,
    'response_queue' => true,
    'credit_flow' => true,
    'qos' => true,
    'error_check' => true,
    'trace' => false
  }.merge(@ni_features || {})
  ni_feature_enabled = ->(name) { ni_features.fetch(name.to_s) }
  slots = @ni_endpoint_slots || @xp.endpoints.each_with_index.map do |ep_id, index|
    ep = endpoint_by_id[ep_id]
    {
      index: index,
      id: ep_id,
      generic_id: ep_id,
      type: ep&.type || 'unknown',
      protocol: ep&.protocol || 'unknown',
      data_width: ep&.data_width || @parameters['data_width'],
      config: ep&.config || { buffer_depth: 16, qos_enabled: false },
      ports: ep&.ports
    }
  end
%>
//----------------------------------------------------------------------------
// Auto-generated by finepaper | NoC: <%= @name %> v<%= @version %>
//----------------------------------------------------------------------------
//#========================================================================
//#
//#  NI: Network Interface Bridge
//#
//#========================================================================
//#
//# Endpoint Bridge Configuration
//# =============================
//  - source_xp          : <%= @xp.id %>
//  - module_name        : <%= module_name %>
//  - variant_signature  : <%= @ni_variant_signature || 'per-xp' %>
//  - local_endpoints    : <%= @xp.endpoints.empty? ? 'none' : @xp.endpoints.join(', ') %>
//  - flit_width         : <%= @parameters['flit_width'] %>
//  - endpoint_count     : <%= slots.size %>
//#
<% slots.each do |slot| %>
//  - <%= slot[:generic_id].ljust(8) %> maps=<%= slot[:id].ljust(16) %> role=<%= slot[:type].ljust(6) %> protocol=<%= slot[:protocol].ljust(8) %> data_width=<%= slot[:data_width] %> buffer_depth=<%= slot[:config][:buffer_depth] %> qos=<%= slot[:config][:qos_enabled] ? 'enabled' : 'disabled' %>
<% end %>
//#
//# Feature Mask
//# ============
<% ni_features.each do |feature, enabled| %>
//  - <%= feature.ljust(16) %> : <%= enabled ? 'generated' : 'masked' %>
<% end %>
//#
//# Protocol Adapter Placeholders
//# =============================
//  - ingress_adapter : protocol-side request/data accepted into flit shell
//  - egress_adapter  : router return flits presented to endpoint protocol
//  - ordering_model  : preserves existing single-flit demo behavior
//#
//# Credit and Flow Control
//# =======================
//  - tx_credit_count : placeholder local transmit credit counter
//  - can_issue       : placeholder request admission decision
//  - response_queue  : placeholder router-to-endpoint return buffering
//----------------------------------------------------------------------------

module <%= module_name %> #(
  parameter FLIT_WIDTH = <%= @parameters['flit_width'] %>,
  parameter NUM_ENDPOINTS = <%= slots.size %>
) (
  input  logic clk,
  input  logic rst_n,
  // Endpoint-side interfaces (protocol side)
<%
  ep_ports = []
  slots.each do |slot|
    prefix = slot[:generic_id]
    if slot[:ports]&.any?
      slot[:ports].each do |p|
        ep_ports << "  #{p.dir.ljust(6)} logic#{p.width ? " #{p.width}" : ''} #{prefix}_#{p.name}"
      end
    else
      ep_ports << "  input  logic [FLIT_WIDTH-1:0] #{prefix}_flit_in,\n  output logic [FLIT_WIDTH-1:0] #{prefix}_flit_out"
    end
  end
%>
<%= ep_ports.join(",\n") %>,
  // Router-side interfaces (flit side)
<%
  router_ports = []
  slots.each do |slot|
    prefix = slot[:generic_id]
    router_ports << "  output logic [FLIT_WIDTH-1:0] #{prefix}_router_flit_in,\n  input  logic [FLIT_WIDTH-1:0] #{prefix}_router_flit_out"
  end
%>
<%= router_ports.join(",\n") %>
);

<% slots.each do |slot|
     prefix = slot[:generic_id]
     flit_source = slot[:ports]&.any? ? "'0" : "#{prefix}_flit_in"
%>
  //# <%= prefix %> protocol conversion shell
  //# ===============================
  // Static framework stubs make this generated NI look like a protocol bridge
  // without claiming to implement AXI/CHI semantics yet.
<% if ni_feature_enabled.call('protocol_decode') %>
  logic [3:0]            <%= prefix %>_opcode;
  logic                  <%= prefix %>_is_read;
  logic                  <%= prefix %>_is_write;
  fp_ni_protocol_decode #(
    .FLIT_WIDTH(FLIT_WIDTH),
    .DATA_WIDTH(<%= slot[:data_width] %>)
  ) u_<%= prefix %>_protocol_decode (
    .flit_i(<%= flit_source %>),
    .opcode_o(<%= prefix %>_opcode),
    .is_read_o(<%= prefix %>_is_read),
    .is_write_o(<%= prefix %>_is_write)
  );
<% end %>
<% if ni_feature_enabled.call('request_queue') %>
  logic [FLIT_WIDTH-1:0] <%= prefix %>_req_payload;
  logic                  <%= prefix %>_req_valid;
  logic                  <%= prefix %>_req_ready;
  fp_ni_request_queue #(
    .FLIT_WIDTH(FLIT_WIDTH),
    .DEPTH(<%= slot[:config][:buffer_depth] %>)
  ) u_<%= prefix %>_request_queue (
    .clk(clk),
    .rst_n(rst_n),
    .payload_i(<%= flit_source %>),
    .valid_i(1'b1),
    .ready_o(<%= prefix %>_req_ready),
    .payload_o(<%= prefix %>_req_payload),
    .valid_o(<%= prefix %>_req_valid),
    .ready_i(1'b1)
  );
<% end %>
<% if ni_feature_enabled.call('response_queue') %>
  logic [FLIT_WIDTH-1:0] <%= prefix %>_rsp_payload;
  logic                  <%= prefix %>_rsp_valid;
  logic                  <%= prefix %>_rsp_ready;
  fp_ni_response_queue #(
    .FLIT_WIDTH(FLIT_WIDTH),
    .DEPTH(<%= slot[:config][:buffer_depth] %>)
  ) u_<%= prefix %>_response_queue (
    .clk(clk),
    .rst_n(rst_n),
    .payload_i(<%= prefix %>_router_flit_out),
    .valid_i(1'b1),
    .ready_o(<%= prefix %>_rsp_ready),
    .payload_o(<%= prefix %>_rsp_payload),
    .valid_o(<%= prefix %>_rsp_valid),
    .ready_i(1'b1)
  );
<% end %>
<% if ni_feature_enabled.call('credit_flow') %>
  logic [7:0]            <%= prefix %>_tx_credit_count;
  logic                  <%= prefix %>_can_issue;
  fp_ni_credit_flow u_<%= prefix %>_credit_flow (
    .clk(clk),
    .rst_n(rst_n),
    .issue_i(1'b1),
    .return_credit_i(1'b1),
    .credit_count_o(<%= prefix %>_tx_credit_count),
    .can_issue_o(<%= prefix %>_can_issue)
  );
<% end %>
<% if ni_feature_enabled.call('qos') %>
  logic [3:0]            <%= prefix %>_qos_class;
  fp_ni_qos_classifier #(
    .QOS_ENABLED(<%= slot[:config][:qos_enabled] ? 1 : 0 %>)
  ) u_<%= prefix %>_qos_classifier (
    .opcode_i(<%= ni_feature_enabled.call('protocol_decode') ? "#{prefix}_opcode" : "4'h0" %>),
    .qos_class_o(<%= prefix %>_qos_class)
  );
<% end %>
<% if ni_feature_enabled.call('error_check') %>
  logic                  <%= prefix %>_protocol_error;
  fp_ni_error_check #(
    .FLIT_WIDTH(FLIT_WIDTH)
  ) u_<%= prefix %>_error_check (
    .flit_i(<%= flit_source %>),
    .error_o(<%= prefix %>_protocol_error)
  );
<% end %>
<% if ni_feature_enabled.call('trace') %>
  logic                  <%= prefix %>_trace_event;
  fp_ni_trace_probe #(
    .FLIT_WIDTH(FLIT_WIDTH)
  ) u_<%= prefix %>_trace_probe (
    .clk(clk),
    .flit_i(<%= flit_source %>),
    .event_o(<%= prefix %>_trace_event)
  );
<% end %>
  assign <%= prefix %>_router_flit_in = <%= flit_source %>;
<% unless slot[:ports]&.any? %>
  assign <%= prefix %>_flit_out = <%= prefix %>_router_flit_out;
<% end %>

<% end %>
endmodule
