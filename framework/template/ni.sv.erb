<%
  endpoint_by_id = @noc.endpoints.to_h { |ep| [ep.id, ep] }
%>
//----------------------------------------------------------------------------
// Auto-generated by finepaper | NoC: <%= @name %> v<%= @version %>
//----------------------------------------------------------------------------
//#========================================================================
//#
//#  NI: Network Interface Bridge
//#
//#========================================================================
//#
//# Endpoint Bridge Configuration
//# =============================
//  - source_xp       : <%= @xp.id %>
//  - local_endpoints : <%= @xp.endpoints.empty? ? 'none' : @xp.endpoints.join(', ') %>
//  - flit_width      : <%= @parameters['flit_width'] %>
//  - endpoint_count  : <%= @xp.endpoints.size %>
//#
<% @xp.endpoints.each do |ep_id|
     ep = endpoint_by_id[ep_id]
     if ep %>
//  - <%= ep.id.ljust(16) %> role=<%= ep.type.ljust(6) %> protocol=<%= ep.protocol.ljust(8) %> data_width=<%= ep.data_width %> buffer_depth=<%= ep.config[:buffer_depth] %> qos=<%= ep.config[:qos_enabled] ? 'enabled' : 'disabled' %>
<%   else %>
//  - <%= ep_id.ljust(16) %> role=unknown protocol=unknown data_width=unknown buffer_depth=unknown qos=unknown
<%   end
   end %>
//#
//# Protocol Adapter Placeholders
//# =============================
//  - ingress_adapter : protocol-side request/data accepted into flit shell
//  - egress_adapter  : router return flits presented to endpoint protocol
//  - ordering_model  : preserves existing single-flit demo behavior
//#
//# Credit and Flow Control
//# =======================
//  - tx_credit_valid : placeholder for endpoint-to-router credit accounting
//  - rx_credit_valid : placeholder for router-to-endpoint return credits
//  - qos_class       : endpoint QoS metadata slot for future arbitration
//----------------------------------------------------------------------------

module ni_xp_<%= @xp.id %> #(
  parameter FLIT_WIDTH = <%= @parameters['flit_width'] %>,
  parameter NUM_ENDPOINTS = <%= @xp.endpoints.size %>
) (
  input  logic clk,
  input  logic rst_n,
  // Endpoint-side interfaces (protocol side)
<%
  ep_ports = []
  @xp.endpoints.each do |ep_id|
    ep = endpoint_by_id[ep_id]
    if ep&.ports&.any?
      ep.ports.each do |p|
        ep_ports << "  #{p.dir.ljust(6)} logic#{p.width ? " #{p.width}" : ''} #{ep_id}_#{p.name}"
      end
    else
      ep_ports << "  input  logic [FLIT_WIDTH-1:0] #{ep_id}_flit_in,\n  output logic [FLIT_WIDTH-1:0] #{ep_id}_flit_out"
    end
  end
%>
<%= ep_ports.join(",\n") %>,
  // Router-side interfaces (flit side)
<%
  router_ports = []
  @xp.endpoints.each do |ep_id|
    router_ports << "  output logic [FLIT_WIDTH-1:0] #{ep_id}_router_flit_in,\n  input  logic [FLIT_WIDTH-1:0] #{ep_id}_router_flit_out"
  end
%>
<%= router_ports.join(",\n") %>
);
  //# Endpoint passthrough datapath
  //# =============================
  // Generated protocol adapters are structural placeholders. Endpoint records
  // without explicit protocol ports keep the original direct flit passthrough.
<% @xp.endpoints.each do |ep_id|
  ep = endpoint_by_id[ep_id]
  unless ep&.ports&.any? %>
  assign <%= ep_id %>_router_flit_in = <%= ep_id %>_flit_in;
  assign <%= ep_id %>_flit_out = <%= ep_id %>_router_flit_out;
<% end
end %>
endmodule
