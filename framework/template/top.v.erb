<%
  xs = @xps.map(&:x)
  ys = @xps.map(&:y)
  mesh_width = xs.empty? ? 0 : xs.max - xs.min + 1
  mesh_height = ys.empty? ? 0 : ys.max - ys.min + 1
  catalog = @noc.catalog
  endpoint_by_id = @endpoints.to_h { |ep| [ep.id, ep] }
  variant_mode = @xp_module_lookup && @xp_link_directions_by_id
%>
//----------------------------------------------------------------------------
// Auto-generated by finepaper | NoC: <%= @name %> v<%= @version %>
//----------------------------------------------------------------------------
//#========================================================================
//#
//#  <%= @name %>: CMN-style generated NoC integration wrapper
//#
//#========================================================================
//#
//# Topology Summary
//# ================
//  - mesh_size      : <%= mesh_width %> x <%= mesh_height %>
//  - xp_count       : <%= @xps.size %>
//  - link_count     : <%= @connections.size %>
//  - endpoint_count : <%= @endpoints.size %>
//  - master_count   : <%= catalog[:masters].size %>
//  - slave_count    : <%= catalog[:slaves].size %>
//  - variant_mode   : <%= variant_mode ? 'partitioned xp signature modules' : 'per-xp router modules' %>
//#
//# Global Configuration Parameters
//# ===============================
<% @parameters.sort_by { |key, _| key.to_s }.each do |key, value| %>
//  - <%= key.to_s.upcase.ljust(20) %> = <%= value %>
<% end %>
//#
//# XP Inventory
//# ============
<% @xps.each do |xp| %>
//  - NID<%= xp.node_id(@noc).to_s.rjust(3, '0') %> <%= xp.id.ljust(16) %> xy=(<%= xp.x %>,<%= xp.y %>) endpoints=<%= xp.endpoints.empty? ? 'none' : xp.endpoints.join(',') %> route=<%= xp.config[:routing_algorithm] %> vc=<%= xp.config[:vc_count] %> depth=<%= xp.config[:buffer_depth] %>
<% end %>
//#
//# Endpoint / Device Inventory
//# ===========================
<% @endpoints.each do |ep| %>
//  - <%= ep.id.ljust(16) %> role=<%= ep.type.ljust(6) %> protocol=<%= ep.protocol.ljust(8) %> data_width=<%= ep.data_width %> buffer_depth=<%= ep.config[:buffer_depth] %> qos=<%= ep.config[:qos_enabled] ? 'enabled' : 'disabled' %>
<% end %>
//#
//# Mesh Link Inventory
//# ===================
<% @connections.each_with_index do |conn, index| %>
//  - L<%= index.to_s.rjust(3, '0') %> <%= conn.from %> -> <%= conn.to %> dir=<%= conn.dir || 'auto' %> channels=REQ,RSP,DAT,SNP,PUB credits=local
<% end %>
//----------------------------------------------------------------------------

module <%= @name %>_top #(
  parameter DATA_WIDTH = <%= @parameters['data_width'] %>,
  parameter FLIT_WIDTH = <%= @parameters['flit_width'] %>,
  parameter ADDR_WIDTH = <%= @parameters['addr_width'] %>
) (
  input  logic clk,
  input  logic rst_n<%
  # Collect all endpoint ports
  @endpoints.each do |ep|
    if ep.ports&.any?
      ep.ports.each { |p| %>,
  <%= p.dir.ljust(6) %> logic<%= p.width ? " [#{p.width}]" : '' %> <%= ep.id %>_<%= p.name %><% }
    else %>,
  input  logic [FLIT_WIDTH-1:0] <%= ep.id %>_flit_in,
  output logic [FLIT_WIDTH-1:0] <%= ep.id %>_flit_out<% end
  end %>
);

  //# Internal Signals - Mesh Link Bundle Declarations
  //# ================================================
  // Each directed link keeps the current simplified flit net plus CMN-style
  // placeholder sidebands for valid, credit, snoop, and public channels.
<%
  wires = {}
  @connections.each do |c|
    wires["#{c.from}_to_#{c.to}"] = true
    wires["#{c.to}_to_#{c.from}"] = true
  end
  wires.keys.each do |w| %>
  logic [FLIT_WIDTH-1:0] link_<%= w %>_flit;
  logic                  link_<%= w %>_reqflitv;
  logic                  link_<%= w %>_rspflitv;
  logic                  link_<%= w %>_datflitv;
  logic                  link_<%= w %>_snpflitv;
  logic                  link_<%= w %>_pubflitv;
  logic                  link_<%= w %>_lcrdv;
  logic [7:0]            link_<%= w %>_rinfo;
  logic [15:0]           link_<%= w %>_globalsig;
<% end %>

  //# Device Attachment Bundle Declarations
  //# =====================================
  // NI-to-router bundles model protocol adapters, request queues, and return
  // paths in the same location a production wrapper would stitch CHI/AXI ports.
<%
  @xps.each do |xp|
    next if xp.endpoints.empty?
    xp.endpoints.each do |ep_id| %>
  logic [FLIT_WIDTH-1:0] ni_<%= ep_id %>_to_router_flit;
  logic [FLIT_WIDTH-1:0] router_to_ni_<%= ep_id %>_flit;
  logic                  ni_<%= ep_id %>_tx_credit_valid;
  logic                  ni_<%= ep_id %>_rx_credit_valid;
  logic [3:0]            ni_<%= ep_id %>_qos_class;
<% end
  end %>

  //# Router Instance Stitching
  //# =========================
<%
  @xps.each do |xp|
    module_name = variant_mode ? @xp_module_lookup.fetch(xp.id) : "xp_router_#{xp.id}" %>
  <%= module_name %> #(
    .DATA_WIDTH(DATA_WIDTH),
    .FLIT_WIDTH(FLIT_WIDTH),
    .ADDR_WIDTH(ADDR_WIDTH)
  ) u_<%= xp.id %> (
    .clk(clk),
    .rst_n(rst_n)<%
    # Connect to neighboring routers
    if variant_mode
      @xp_link_directions_by_id.fetch(xp.id).each do |link|
        nb = link[:neighbor]
        port = link[:port] || link[:abbr] %>,
    .flit_out_<%= port %>(link_<%= xp.id %>_to_<%= nb.id %>_flit),
    .flit_in_<%= port %>(link_<%= nb.id %>_to_<%= xp.id %>_flit)<% end
    else
      xp.neighbors(self).each do |nb|
        conn = @connections.find { |c| (c.from == xp.id && c.to == nb.id) || (c.to == xp.id && c.from == nb.id) }
        if conn.from == xp.id
          wire_name = "link_#{xp.id}_to_#{nb.id}" %>,
    .flit_out_<%= nb.id %>(<%=wire_name%>_flit),
    .flit_in_<%= nb.id %>(link_<%= nb.id %>_to_<%= xp.id %>_flit)<% else
          wire_name = "link_#{nb.id}_to_#{xp.id}" %>,
    .flit_in_<%= nb.id %>(<%=wire_name%>_flit),
    .flit_out_<%= nb.id %>(link_<%= xp.id %>_to_<%= nb.id %>_flit)<% end
      end
    end
    # Connect endpoints via NI wires
    if variant_mode
      xp.endpoints.each_with_index do |ep_id, idx| %>,
    .local<%= idx %>_flit_in(ni_<%= ep_id %>_to_router_flit),
    .local<%= idx %>_flit_out(router_to_ni_<%= ep_id %>_flit)<% end
    else
      xp.endpoints.each do |ep_id|
        ep = endpoint_by_id[ep_id]
        if ep&.ports&.any?
          ep.ports.each { |p| %>,
    .<%= ep_id %>_<%= p.name %>(<%= ep_id %>_<%= p.name %>)<% }
        else %>,
    .<%= ep_id %>_flit_in(ni_<%= ep_id %>_to_router_flit),
    .<%= ep_id %>_flit_out(router_to_ni_<%= ep_id %>_flit)<% end
      end
    end %>
  );

<% end %>
  //# Network Interface Instance Stitching
  //# ====================================
<%
  @xps.each do |xp|
    next if xp.endpoints.empty? %>
  ni_xp_<%= xp.id %> #(
    .FLIT_WIDTH(FLIT_WIDTH),
    .NUM_ENDPOINTS(<%= xp.endpoints.size %>)
  ) u_ni_<%= xp.id %> (
    .clk(clk),
    .rst_n(rst_n)<%
    xp.endpoints.each do |ep_id|
      ep = endpoint_by_id[ep_id]
      if ep&.ports&.any?
        ep.ports.each { |p| %>,
    .<%= ep_id %>_<%= p.name %>(<%= ep_id %>_<%= p.name %>)<% }
        if variant_mode %>,
    .<%= ep_id %>_router_flit_in(ni_<%= ep_id %>_to_router_flit),
    .<%= ep_id %>_router_flit_out(router_to_ni_<%= ep_id %>_flit)<% end
      else %>,
    .<%= ep_id %>_flit_in(<%= ep_id %>_flit_in),
    .<%= ep_id %>_flit_out(<%= ep_id %>_flit_out),
    .<%= ep_id %>_router_flit_in(ni_<%= ep_id %>_to_router_flit),
    .<%= ep_id %>_router_flit_out(router_to_ni_<%= ep_id %>_flit)<% end
    end %>
  );

<% end %>
endmodule
