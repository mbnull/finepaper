<?xml version="1.0" encoding="UTF-8"?>
<module-bundle>
  <module name="Endpoint" palette_label="Endpoint" graph_group="endpoints" description="Endpoint interface block that terminates a local NoC connection.">
    <identity external_id_prefix="ep" display_prefix="EP" width="2" supports_mesh_coordinates="false" />
    <ports>
      <port id="noc" direction="input" type="bus" bus_type="ni2router" role="attachment" name="NoC" description="NoC attachment input" />
    </ports>
    <parameters>
      <parameter name="display_name" type="string" label="Display name" description="Name shown on the canvas." />
      <parameter name="external_id" type="string" label="External ID" description="Framework-facing identifier." />
      <parameter name="type" type="string" default="master" label="Type" description="Endpoint traffic role.">
        <choices>
          <choice value="master" label="Master" />
          <choice value="slave" label="Slave" />
        </choices>
      </parameter>
      <parameter name="protocol" type="string" default="axi" label="Protocol" description="Interface protocol." />
      <parameter name="data_width" type="int" default="32" label="Data width" description="Bus width in bits." minimum="1" unit="bits" />
      <parameter name="buffer_depth" type="int" default="16" label="Buffer depth" description="Ingress buffer depth." minimum="1" />
      <parameter name="qos_enabled" type="bool" default="false" label="QoS enabled" description="Enable QoS tagging support." />
    </parameters>
  </module>
  <module name="XP" palette_label="XP" graph_group="xps" description="Mesh router with four directional links and four local endpoint attachment slots.">
    <identity external_id_prefix="xp" display_prefix="XP" width="2" supports_mesh_coordinates="true" />
    <capabilities supports_collapse="true" />
    <ports>
      <port id="ep0" direction="output" type="bus" bus_type="ni2router" role="attachment" name="EP0" description="Local endpoint slot 0" />
      <port id="ep1" direction="output" type="bus" bus_type="ni2router" role="attachment" name="EP1" description="Local endpoint slot 1" />
      <port id="ep2" direction="output" type="bus" bus_type="ni2router" role="attachment" name="EP2" description="Local endpoint slot 2" />
      <port id="ep3" direction="output" type="bus" bus_type="ni2router" role="attachment" name="EP3" description="Local endpoint slot 3" />
      <port id="north_in" direction="input" type="bus" bus_type="router" role="router" name="N" description="North router ingress" />
      <port id="north_out" direction="output" type="bus" bus_type="router" role="router" name="N" description="North router egress" />
      <port id="east_in" direction="input" type="bus" bus_type="router" role="router" name="E" description="East router ingress" />
      <port id="east_out" direction="output" type="bus" bus_type="router" role="router" name="E" description="East router egress" />
      <port id="south_in" direction="input" type="bus" bus_type="router" role="router" name="S" description="South router ingress" />
      <port id="south_out" direction="output" type="bus" bus_type="router" role="router" name="S" description="South router egress" />
      <port id="west_in" direction="input" type="bus" bus_type="router" role="router" name="W" description="West router ingress" />
      <port id="west_out" direction="output" type="bus" bus_type="router" role="router" name="W" description="West router egress" />
    </ports>
    <parameters>
      <parameter name="x" type="int" default="0" description="Canvas X position." configurable="false" />
      <parameter name="y" type="int" default="0" description="Canvas Y position." configurable="false" />
      <parameter name="display_name" type="string" label="Display name" description="Name shown on the canvas." />
      <parameter name="external_id" type="string" label="External ID" description="Framework-facing identifier." />
      <parameter name="collapsed" type="bool" default="true" description="Collapsed editor state." configurable="false" />
      <parameter name="routing_algorithm" type="string" default="xy" label="Routing algorithm" description="Router path selection strategy.">
        <choices>
          <choice value="xy" label="XY" />
          <choice value="yx" label="YX" />
        </choices>
      </parameter>
      <parameter name="vc_count" type="int" default="2" label="VC count" description="Virtual channel count." minimum="1" maximum="8" unit="VCs" />
      <parameter name="buffer_depth" type="int" default="8" label="Buffer depth" description="Depth of each input buffer." minimum="1" />
    </parameters>
  </module>
</module-bundle>
